---
export interface Props {
    title?: string;
}

const { title = "Tranzit" } = Astro.props as Props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
            }
            body {
                font-family:
                    system-ui,
                    -apple-system,
                    sans-serif;
                max-width: 800px;
                margin: 0 auto;
                padding: 1rem;
                line-height: 1.6;
            }
            a {
                color: #1a5fb4;
            }
            a:hover {
                text-decoration: underline;
            }
            h1 {
                margin-top: 0;
            }
        </style>
    </head>
    <body>
        <slot />
    </body>
</html>
